<Window x:Class="PDVModerno.Views.DescontoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aplicar Desconto" Width="400" SizeToContent="Height" MinHeight="250"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        Background="{StaticResource BgDark}"
        Foreground="White">
    <StackPanel Margin="20">
        <TextBlock Text="Aplicar Desconto" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource PrimaryColor}"/>

        <TextBlock Text="Selecione o Produto:" FontSize="14" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
        <ComboBox x:Name="CmbProdutos" Margin="0,0,0,15" Padding="5" FontSize="14"
                  Background="{StaticResource BgDark}" Foreground="{StaticResource TextPrimary}"
                  BorderBrush="{StaticResource BgPanelLighter}" BorderThickness="1"
                  DisplayMemberPath="Produto.Nome">
        </ComboBox>

        <TextBlock Text="Valor do Desconto (R$):" FontSize="14" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
        <TextBox x:Name="TxtDesconto" FontSize="18" Padding="8" Margin="0,0,0,20" 
                 Background="{StaticResource BgPanel}" Foreground="{StaticResource TextPrimary}" 
                 BorderBrush="{StaticResource BgPanelLighter}" BorderThickness="1" HorizontalContentAlignment="Center"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Cancelar" Click="BtnCancelar_Click" Style="{StaticResource DangerButtonStyle}" Padding="10,8" />
            <Button Grid.Column="2" Content="Confirmar" Click="BtnConfirmar_Click" Style="{StaticResource SuccessButtonStyle}" Padding="10,8" IsDefault="True" />
        </Grid>
    </StackPanel>
</Window>
