<Window x:Class="PDVModerno.Views.PagamentoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Finalizar Venda - Pagamento" Width="500" SizeToContent="Height" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        Background="{StaticResource BgDark}"
        Foreground="White">
    <Window.Resources>
        <Style x:Key="PaymentMethodButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="{StaticResource BgPanelLighter}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="2,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}" BorderBrush="{StaticResource BgPanelLighter}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BgDark}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryColor}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryColor}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Titulo -->
            <RowDefinition Height="Auto" /> <!-- Total a Pagar -->
            <RowDefinition Height="Auto" /> <!-- Metodos de Pagamento -->
            <RowDefinition Height="*" />    <!-- Area de Detalhes Dinamicos -->
            <RowDefinition Height="Auto" /> <!-- Botoes de Acao -->
        </Grid.RowDefinitions>

        <!-- 1. Titulo -->
        <TextBlock Grid.Row="0" Text="Método de Pagamento" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource PrimaryColor}"/>

        <!-- 2. Total a Pagar -->
        <Border Grid.Row="1" Background="{StaticResource BgPanelLighter}" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <Grid>
                <TextBlock Text="Total a Pagar:" FontSize="16" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtTotalPagar" Text="R$ 0,00" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessColor}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- 3. Metodos de Pagamento (Botoes de Selecao) -->
        <UniformGrid Grid.Row="2" Columns="4" Height="50" Margin="0,0,0,20">
            <RadioButton x:Name="RadDinheiro" Content="💵 Dinheiro" Style="{StaticResource PaymentMethodButtonStyle}" GroupName="Metodo" IsChecked="True" Checked="Metodo_Checked"/>
            <RadioButton x:Name="RadPix" Content="⚡ PIX" Style="{StaticResource PaymentMethodButtonStyle}" GroupName="Metodo" Checked="Metodo_Checked"/>
            <RadioButton x:Name="RadCredito" Content="💳 Crédito" Style="{StaticResource PaymentMethodButtonStyle}" GroupName="Metodo" Checked="Metodo_Checked"/>
            <RadioButton x:Name="RadDebito" Content="💳 Débito" Style="{StaticResource PaymentMethodButtonStyle}" GroupName="Metodo" Checked="Metodo_Checked"/>
        </UniformGrid>

        <!-- 4. Area de Detalhes Dinamicos -->
        <Grid Grid.Row="3" MinHeight="180" Margin="0,0,0,20">
            <!-- PAINEL DINHEIRO -->
            <StackPanel x:Name="PanelDinheiro" Visibility="Visible">
                <TextBlock Text="Valor Recebido (R$):" FontSize="14" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtValorRecebido" FontSize="22" Padding="10" TextAlignment="Center" FontWeight="Bold"
                         Background="{StaticResource BgPanel}" Foreground="{StaticResource TextPrimary}" 
                         BorderBrush="{StaticResource BgPanelLighter}" BorderThickness="1"
                         TextChanged="TxtValorRecebido_TextChanged" GotFocus="TxtValorRecebido_GotFocus"/>

                <Grid Margin="0,15,0,0">
                    <TextBlock Text="Troco:" FontSize="18" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtTroco" Text="R$ 0,00" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>

            <!-- PAINEL PIX -->
            <Grid x:Name="PanelPix" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="5" Width="140" Height="140" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid>
                        <Image x:Name="ImgQrCode" Stretch="Uniform"/>
                        <TextBlock x:Name="TxtCarregandoPix" Text="Gerando QR..." Foreground="Black" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="⚡ Pagamento por PIX" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtInstrucoesPix" Text="Escaneie o QR Code ao lado usando seu aplicativo de banco." FontSize="12" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <TextBox x:Name="TxtChavePix" Text="Gerando chave..." FontSize="10" Foreground="{StaticResource TextPrimary}" Background="{StaticResource BgPanel}" IsReadOnly="True" Margin="0,0,0,10" ToolTip="Código Pix Copia e Cola"/>
                    
                    <TextBlock x:Name="TxtStatusPix" Text="Aguardando pagamento..." FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                </StackPanel>
            </Grid>

            <!-- PAINEL CARTÃO -->
            <StackPanel x:Name="PanelCartao" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="💳 Operação de Cartão" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Insira ou aproxime o cartão na maquininha..." FontSize="14" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <Button Content="Confirmar Transação de Cartão" Style="{StaticResource SuccessButtonStyle}" Click="BtnConfirmarCartao_Click" Padding="20,10" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- 5. Botoes de Acao -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="15" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Cancelar" Click="BtnCancelar_Click" Style="{StaticResource DangerButtonStyle}" Height="45" FontSize="14" />
            <Button Grid.Column="2" x:Name="BtnConfirmar" Content="Confirmar Venda" Click="BtnConfirmar_Click" Style="{StaticResource SuccessButtonStyle}" Height="45" FontSize="14" IsEnabled="False"/>
        </Grid>

        <!-- Overlay de Sucesso -->
        <Border x:Name="OverlaySucesso" Grid.RowSpan="5" Background="#F2121212" CornerRadius="10" Visibility="Collapsed" Panel.ZIndex="200">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Círculo de Checkmark com efeito de brilho -->
                <Border Width="90" Height="90" CornerRadius="45" Background="#1A00C853" BorderBrush="{StaticResource SuccessColor}" BorderThickness="3" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="✓" FontSize="52" FontWeight="Bold" Foreground="{StaticResource SuccessColor}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-3,0,0"/>
                </Border>
                <TextBlock Text="PAGAMENTO CONFIRMADO" FontSize="20" FontWeight="Bold" Foreground="{StaticResource SuccessColor}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Finalizando venda e gerando recibo..." FontSize="13" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
