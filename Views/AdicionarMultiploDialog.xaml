<Window x:Class="PDVModerno.Views.AdicionarMultiploDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adicionar Múltiplos Itens" Width="350" SizeToContent="Height" MinHeight="250"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        Background="{StaticResource BgDark}"
        Foreground="White">
    <StackPanel Margin="20">
        <TextBlock Text="Adicionar Múltiplos" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource PrimaryColor}"/>

        <TextBlock Text="Quantidade:" FontSize="14" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
        <TextBox x:Name="TxtQuantidade" FontSize="18" Padding="8" Margin="0,0,0,15" Text="1"
                 Background="{StaticResource BgPanel}" Foreground="{StaticResource TextPrimary}" 
                 BorderBrush="{StaticResource BgPanelLighter}" BorderThickness="1" HorizontalContentAlignment="Center"/>

        <TextBlock Text="Código de Barras:" FontSize="14" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
        <TextBox x:Name="TxtCodigoBarras" FontSize="18" Padding="8" Margin="0,0,0,20" 
                 Background="{StaticResource BgPanel}" Foreground="{StaticResource TextPrimary}" 
                 BorderBrush="{StaticResource BgPanelLighter}" BorderThickness="1" HorizontalContentAlignment="Center"
                 KeyDown="TxtCodigoBarras_KeyDown"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Cancelar" Click="BtnCancelar_Click" Style="{StaticResource DangerButtonStyle}" Padding="10,8" />
            <Button Grid.Column="2" Content="Confirmar" Click="BtnConfirmar_Click" Style="{StaticResource SuccessButtonStyle}" Padding="10,8" IsDefault="True" />
        </Grid>
    </StackPanel>
</Window>
