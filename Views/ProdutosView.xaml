<UserControl x:Class="PDVModerno.Views.ProdutosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Formulário (Esquerda) -->
        <Border Grid.Column="0" Background="{StaticResource BgPanel}" CornerRadius="10" Padding="20" Margin="0,0,15,0">
            <StackPanel>
                <TextBlock Text="Novo Produto" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"/>

                <TextBlock Text="Código de Barras (Escaneie aqui)" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtCodigoBarras" Margin="0,0,0,15" Padding="5" />

                <TextBlock Text="Nome do Produto" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtNome" Margin="0,0,0,15" Padding="5" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Preço Custo (R$)" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtPrecoCusto" Margin="0,0,0,15" Padding="5" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Preço Venda (R$)" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtPreco" Margin="0,0,0,15" Padding="5" />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Estoque Inicial" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtEstoque" Margin="0,0,0,15" Padding="5" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Categoria" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                <ComboBox x:Name="CmbCategoria" Margin="0,0,0,25" Padding="5" IsEditable="True" 
                          Background="{StaticResource BgDark}" Foreground="{StaticResource TextPrimary}"
                          BorderBrush="{StaticResource BgPanelLighter}" BorderThickness="1">
                    <ComboBox.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#121212" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FFFFFF" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#6C63FF" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF" />
                    </ComboBox.Resources>
                </ComboBox>

                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="BtnSalvar" Content="SALVAR PRODUTO" Style="{StaticResource SuccessButtonStyle}" Click="BtnSalvar_Click" Height="45"/>
                    <Button Grid.Column="2" x:Name="BtnCancelarEdicao" Content="Cancelar" Style="{StaticResource DangerButtonStyle}" Click="BtnCancelarEdicao_Click" Height="45" Visibility="Collapsed" Padding="20,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Lista de Produtos Cadastrados (Direita) -->
        <Border Grid.Column="1" Background="{StaticResource BgPanel}" CornerRadius="10" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="Produtos Cadastrados" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"/>
                
                <DataGrid x:Name="GridProdutos" 
                          Grid.Row="1"
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          HeadersVisibility="Column"
                          Background="Transparent"
                          RowBackground="{StaticResource BgPanelLighter}"
                          AlternatingRowBackground="{StaticResource BgPanel}"
                          Foreground="{StaticResource TextPrimary}"
                          BorderThickness="0"
                          GridLinesVisibility="None"
                          IsReadOnly="True"
                          FontSize="14">
                    
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource BgDark}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="15,10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="15,10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código" Binding="{Binding CodigoBarras}" Width="80"/>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*"/>
                        <DataGridTextColumn Header="Preço Venda" Binding="{Binding Preco, StringFormat='R$ \{0:N2\}'}" Width="100"/>
                        <DataGridTemplateColumn Header="Ações" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Editar" Tag="{Binding}" Click="BtnEditar_Click" 
                                                Background="Transparent" Foreground="{StaticResource PrimaryColor}" 
                                                BorderThickness="0" Cursor="Hand" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <Button Content="Excluir" Tag="{Binding}" Click="BtnExcluir_Click" 
                                                Background="Transparent" Foreground="{StaticResource DangerColor}" 
                                                BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
