<UserControl x:Class="PDVModerno.Views.PDVView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:PDVModerno.Models"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="350" />
        </Grid.ColumnDefinitions>

        <!-- Area de Produtos (Esquerda) -->
        <Border Grid.Row="0" Grid.Column="0" Margin="0,0,10,0" Background="{StaticResource BgPanel}" CornerRadius="10" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Catálogo de Produtos" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="TxtLeitorCodigo" Margin="20,0,0,0" Padding="10" FontSize="14" 
                             ToolTip="Passe o leitor de código de barras aqui"
                             Text="Clique aqui para o leitor de barras..."
                             GotFocus="TxtLeitorCodigo_GotFocus"
                             LostFocus="TxtLeitorCodigo_LostFocus"
                             KeyDown="TxtLeitorCodigo_KeyDown" />
                </Grid>
                
                <Grid Grid.Row="1">
                    <!-- Marca d'água do Carrinho -->
                    <Image Source="/Assets/shopping_cart_watermark.png" 
                           Opacity="0.1" 
                           Width="400" Height="400" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ListaProdutos">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:Produto}">
                                <Border Width="180" Height="220" Margin="0,0,15,15" Background="{StaticResource BgPanelLighter}" CornerRadius="12">
                                    <!-- Efeito de Sombra e Borda Opcional -->
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.3" ShadowDepth="4"/>
                                    </Border.Effect>
                                    
                                    <Grid Margin="15">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Placeholder Imagem -->
                                        <Border Grid.Row="0" Background="{StaticResource BgDark}" CornerRadius="8" Margin="0,0,0,10">
                                            <TextBlock Text="📦" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource PrimaryColor}"/>
                                        </Border>
                                        
                                        <TextBlock Grid.Row="1" Text="{Binding Nome}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" MaxHeight="40" Margin="0,0,0,5"/>
                                        <TextBlock Grid.Row="2" Text="{Binding Preco, StringFormat='R$ \{0:N2\}'}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,10"/>
                                        
                                        <Button Grid.Row="3" Content="Adicionar" Style="{StaticResource ModernButtonStyle}" Tag="{Binding}" Click="BtnAdicionar_Click" Padding="10,8" FontSize="12"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!-- Carrinho / Checkout (Direita) -->
        <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource BgPanel}" CornerRadius="10" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="Carrinho" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"/>
                
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20">
                    <ItemsControl x:Name="ListaCarrinho">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ItemVenda}">
                                <Border Background="{StaticResource BgPanelLighter}" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Produto.Nome}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                <TextBlock Text="{Binding Quantidade, StringFormat='\{0\} x '}" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                                <TextBlock Text="{Binding Produto.Preco, StringFormat='R$ \{0:N2\}'}" FontSize="12" Foreground="{StaticResource PrimaryColor}"/>
                                                <TextBlock Text="{Binding Desconto, StringFormat=' (Desc: -R$ \{0:N2\})'}" FontSize="12" Foreground="{StaticResource SuccessColor}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Desconto}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Subtotal, StringFormat='R$ \{0:N2\}'}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Right"/>
                                            <Button Content="Remover" Tag="{Binding}" Click="BtnRemover_Click" Background="Transparent" Foreground="{StaticResource DangerColor}" BorderThickness="0" Cursor="Hand" Margin="0,5,0,0" HorizontalAlignment="Right" FontSize="12" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <!-- Totais e Botoes de Acao -->
                <StackPanel Grid.Row="2">
                    <Border BorderThickness="0,1,0,0" BorderBrush="{StaticResource BgPanelLighter}" Margin="0,0,0,15" Padding="0,15,0,0">
                        <Grid>
                            <TextBlock Text="Total:" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock x:Name="TxtTotal" Text="R$ 0,00" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                    
                    <Button Content="FINALIZAR VENDA" Style="{StaticResource SuccessButtonStyle}" Click="BtnFinalizarVenda_Click" Height="50" FontSize="16" Margin="0,0,0,10"/>
                    <Button Content="CANCELAR" Style="{StaticResource DangerButtonStyle}" Click="BtnCancelarVenda_Click" Height="40"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Barra de Atalhos Inferior -->
        <Border Grid.Row="1" Grid.ColumnSpan="2" Background="{StaticResource BgPanel}" CornerRadius="10" Margin="0,10,0,0" Padding="15,10">
            <UniformGrid Columns="5" HorizontalAlignment="Stretch">
                <TextBlock HorizontalAlignment="Center" FontSize="13" Foreground="{StaticResource TextSecondary}">
                    <Run Text="[F1]" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                    <Run Text=" Multiplicador" />
                </TextBlock>
                <TextBlock HorizontalAlignment="Center" FontSize="13" Foreground="{StaticResource TextSecondary}">
                    <Run Text="[F2]" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                    <Run Text=" Aplicar Desconto" />
                </TextBlock>
                <TextBlock HorizontalAlignment="Center" FontSize="13" Foreground="{StaticResource TextSecondary}">
                    <Run Text="[F3]" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                    <Run Text=" Menu Produtos" />
                </TextBlock>
                <TextBlock HorizontalAlignment="Center" FontSize="13" Foreground="{StaticResource TextSecondary}">
                    <Run Text="[F5]" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                    <Run Text=" Abrir/Fechar Caixa" />
                </TextBlock>
                <TextBlock HorizontalAlignment="Center" FontSize="13" Foreground="{StaticResource TextSecondary}">
                    <Run Text="[Espaço]" FontWeight="Bold" Foreground="{StaticResource SuccessColor}"/>
                    <Run Text=" Finalizar Venda" />
                </TextBlock>
            </UniformGrid>
        </Border>

        <!-- Overlay CAIXA FECHADO -->
        <Border x:Name="OverlayCaixaFechado" Grid.RowSpan="2" Grid.ColumnSpan="2" Background="#D8000000" Visibility="Collapsed" Panel.ZIndex="100">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🔒 CAIXA FECHADO" FontSize="48" FontWeight="Bold" Foreground="{StaticResource DangerColor}" HorizontalAlignment="Center"/>
                <TextBlock Text="Pressione F5 para abrir o caixa." FontSize="20" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,15,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
