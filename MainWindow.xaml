<Window x:Class="PDVModerno.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDV Moderno" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        Background="{StaticResource BgDark}"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource BgPanel}">
            <StackPanel Margin="0,30,0,0">
                <!-- Logo / Titulo -->
                <TextBlock Text="MEU PDV" 
                           Foreground="{StaticResource PrimaryColor}" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,40"/>

                <!-- Botoes de Navegacao -->
                <RadioButton x:Name="NavPdv" Content="💳 Caixa (PDV)" 
                             Style="{StaticResource SidebarButtonStyle}" 
                             IsChecked="True"
                             Checked="NavPdv_Checked"/>
                
                <RadioButton x:Name="NavProdutos" Content="📦 Produtos" 
                             Style="{StaticResource SidebarButtonStyle}"
                             Checked="NavProdutos_Checked"/>
                
                <RadioButton Content="📊 Estoque" 
                             Style="{StaticResource SidebarButtonStyle}"
                             Checked="NavEstoque_Checked"/>

                <RadioButton x:Name="NavSuporte" Content="💬 Suporte Técnico" 
                             Style="{StaticResource SidebarButtonStyle}"
                             Checked="NavSuporte_Checked"/>
                             
                <Button Content="🚪 Sair do Sistema" 
                        Style="{StaticResource DangerButtonStyle}"
                        Margin="10,40,10,0"
                        Click="BtnSair_Click"/>
            </StackPanel>
        </Border>

        <!-- Area de Conteudo -->
        <Border Grid.Column="1" Background="{StaticResource BgDark}">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock x:Name="TxtRelogio" Grid.Row="0" Text="00:00:00" 
                           Foreground="{StaticResource PrimaryColor}" 
                           FontSize="48" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>
                           
                <ContentControl x:Name="MainContent" Grid.Row="1" />
            </Grid>
        </Border>
    </Grid>
</Window>
