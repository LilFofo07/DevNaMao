<UserControl x:Class="PDVCentral.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="140" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="Painel Geral" Foreground="{StaticResource TextPrimary}" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="Acompanhamento e monitoramento de transações em tempo real" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Grid de Cards de Métricas -->
        <Grid Grid.Row="1" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Card 1: Total Clientes -->
            <Border Grid.Column="0" Background="{StaticResource BgPanel}" CornerRadius="12" BorderBrush="{StaticResource BgPanelLighter}" BorderThickness="1" Margin="0,0,15,0">
                <Grid Margin="20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Clientes Cadastrados" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="Medium"/>
                        <TextBlock x:Name="TxtTotalClientes" Text="0" Foreground="{StaticResource TextPrimary}" FontSize="32" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock Text="Pontos de venda ativos" Foreground="{StaticResource SuccessColor}" FontSize="12" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Card 2: Faturamento Total -->
            <Border Grid.Column="1" Background="{StaticResource BgPanel}" CornerRadius="12" BorderBrush="{StaticResource BgPanelLighter}" BorderThickness="1" Margin="0,0,15,0">
                <Grid Margin="20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Volume de Vendas Reportado" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="Medium"/>
                        <TextBlock x:Name="TxtVolumeTotal" Text="R$ 0,00" Foreground="{StaticResource TextPrimary}" FontSize="32" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock Text="Total processado pelos PDVs" Foreground="{StaticResource SuccessColor}" FontSize="12" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Card 3: Total Transações -->
            <Border Grid.Column="2" Background="{StaticResource BgPanel}" CornerRadius="12" BorderBrush="{StaticResource BgPanelLighter}" BorderThickness="1">
                <Grid Margin="20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Transações Monitoradas" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="Medium"/>
                        <TextBlock x:Name="TxtTotalTransacoes" Text="0" Foreground="{StaticResource TextPrimary}" FontSize="32" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock Text="Pagamentos recebidos hoje" Foreground="{StaticResource SuccessColor}" FontSize="12" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Grid de Vendas Recentes -->
        <Border Grid.Row="2" Background="{StaticResource BgPanel}" CornerRadius="12" BorderBrush="{StaticResource BgPanelLighter}" BorderThickness="1">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Transações Monitoradas Recentes" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <!-- Lista de transações -->
                <DataGrid x:Name="GridVendas" Grid.Row="1" Background="Transparent" Foreground="White" BorderThickness="0" 
                          AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="None" RowBackground="Transparent" AlternatingRowBackground="#08FFFFFF">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1E1E2D"/>
                            <Setter Property="Foreground" Value="#9499B3"/>
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BgPanelLighter}"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="12,12"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#252538"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="CNPJ do Cliente" Binding="{Binding Cnpj}" Width="150" />
                        <DataGridTextColumn Header="Método" Binding="{Binding Metodo}" Width="100"/>
                        <DataGridTextColumn Header="Valor" Binding="{Binding Valor, StringFormat=C}" Width="120" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                        <DataGridTextColumn Header="Data/Hora" Binding="{Binding Timestamp, StringFormat='dd/MM/yyyy HH:mm:ss'}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
