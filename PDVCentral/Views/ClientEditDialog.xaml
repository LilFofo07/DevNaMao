<Window x:Class="PDVCentral.Views.ClientEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurar Cliente" 
        Height="480" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDark}"
        ResizeMode="NoResize">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" x:Name="TxtTitulo" Text="Configurar Credenciais do Cliente" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Formulário -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Nome -->
                <TextBlock Text="Razão Social / Nome Fantasia:" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtNome" Height="38" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

                <!-- CNPJ -->
                <TextBlock Text="CNPJ ou CPF (Somente Números):" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtCnpj" Height="38" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

                <!-- E-mail -->
                <TextBlock Text="E-mail de Contato:" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtEmail" Height="38" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

                <!-- Token Mercado Pago -->
                <TextBlock Text="Mercado Pago Access Token:" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtToken" Height="38" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                <!-- Área de Validação do Token -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnTestarToken" Content="Testar Token Real" Style="{StaticResource ModernButtonStyle}" Background="#3A3A4E" Padding="15,8" Click="BtnTestarToken_Click"/>
                    <TextBlock x:Name="TxtResultadoTeste" Grid.Column="1" Text="" Foreground="{StaticResource TextSecondary}" FontSize="13" VerticalAlignment="Center" Margin="15,0,0,0" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Ações do Rodapé -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancelar" Style="{StaticResource DangerButtonStyle}" Margin="0,0,10,0" Width="100" Click="BtnCancelar_Click"/>
            <Button Content="Salvar" Style="{StaticResource SuccessButtonStyle}" Width="100" Click="BtnSalvar_Click"/>
        </StackPanel>
    </Grid>
</Window>
